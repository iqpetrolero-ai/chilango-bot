# Copia este archivo como ".env" y llena los valores

# Clave de API de Anthropic (Claude)
# Obtén la tuya en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# Meta WhatsApp Business API
META_ACCESS_TOKEN=EAAXXX...
META_PHONE_NUMBER_ID=1234567890
META_VERIFY_TOKEN=tu_token_de_verificacion
# App Secret de Meta — obtenlo en Meta for Developers > Tu App > Configuración básica
# Necesario para validar firma HMAC de webhooks (seguridad crítica)
META_APP_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Panel de administración
ADMIN_PASSWORD=cambia_esta_clave_en_produccion

# Teléfonos
OWNER_PHONE=51XXXXXXXXX
YAPE_PLIN_NUMBER=XXXXXXXXX

# Datos del negocio
OWNER_NAME=Tu Nombre Aquí
PICKUP_ADDRESS=Dirección exacta del local
